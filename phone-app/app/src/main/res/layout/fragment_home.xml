<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0a0e14" android:padding="16dp">
    <LinearLayout android:orientation="vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:id="@+id/serverInfo" android:text="服务器: ---"
            android:textColor="#6b7280" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/statusText" android:text="未连接"
            android:textColor="#00e5a0" android:textSize="16sp" android:layout_marginBottom="16dp"/>
        <LinearLayout android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btnStart" android:text="启动" android:layout_weight="1"/>
            <Button android:id="@+id/btnStop" android:text="停止" android:layout_weight="1"/>
        </LinearLayout>
        <TextView android:text="选择模式" android:textColor="#c8ccd4" android:textSize="14sp" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btnMatch" android:text="🏆 比赛模式" android:layout_marginBottom="6dp"
            style="@style/ModeButton"/>
        <Button android:id="@+id/btnTraining" android:text="🎯 训练模式" android:layout_marginBottom="6dp"
            style="@style/ModeButton"/>
        <Button android:id="@+id/btnChallenge" android:text="⭐ 闯关模式"
            style="@style/ModeButton"/>
    </LinearLayout>
</ScrollView>
