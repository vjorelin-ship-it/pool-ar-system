<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0a0e14" android:padding="16dp">
    <LinearLayout android:orientation="vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="服务器设置" android:textColor="#c8ccd4" android:textSize="14sp" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/hostInput" android:hint="IP地址"
            android:textColor="#c8ccd4" android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/portInput" android:hint="端口"
            android:textColor="#c8ccd4" android:inputType="number" android:layout_marginBottom="8dp"/>
        <LinearLayout android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btnSave" android:text="保存" android:layout_weight="1"/>
            <Button android:id="@+id/btnDiscover" android:text="自动发现" android:layout_weight="1"/>
        </LinearLayout>

        <TextView android:text="投影校准" android:textColor="#c8ccd4" android:textSize="14sp" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/calStatus" android:text="未校准" android:textColor="#6b7280" android:textSize="12sp"/>
        <LinearLayout android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btnCalStart" android:text="开始校准" android:layout_weight="1"/>
            <Button android:id="@+id/btnCalStop" android:text="停止" android:layout_weight="1"/>
        </LinearLayout>

        <TextView android:text="轨迹数据采集" android:textColor="#c8ccd4" android:textSize="14sp" android:layout_marginBottom="8dp"/>
        <LinearLayout android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btnCollectStart" android:text="开始采集" android:layout_weight="1"/>
            <Button android:id="@+id/btnCollectStop" android:text="停止采集" android:layout_weight="1"/>
        </LinearLayout>

        <TextView android:text="模型状态" android:textColor="#c8ccd4" android:textSize="14sp" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/modelStatus" android:text="点击查询" android:textColor="#6b7280" android:textSize="12sp"/>
        <Button android:id="@+id/btnModelStatus" android:text="查询模型状态" android:layout_marginTop="4dp"/>
    </LinearLayout>
</ScrollView>
